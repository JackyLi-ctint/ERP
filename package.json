{
  "name": "erp-leave-management",
  "version": "0.1.0",
  "description": "Employee Leave Management System",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "test": "npm run test --workspace=server && npm run test --workspace=client",
    "test:e2e": "playwright test",
    "build": "npm run build --workspace=server && npm run build --workspace=client"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "*"
  }
}
