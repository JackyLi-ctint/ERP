# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leave_management
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=leave_management

# JWT Configuration (required - use strong random values in production)
JWT_ACCESS_SECRET=your_access_secret_key_here_min_32_chars_required
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_chars_required
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server Configuration
NODE_ENV=development
PORT=3000

# SSO Configuration (disabled by default, enabled in Phase 7)
SSO_ENABLED=false

# Email (SMTP) — optional, leave blank to disable email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Azure Entra ID (OIDC) — required for Microsoft SSO
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:3000/api/auth/azure/callback
FRONTEND_URL=http://localhost:5173
